# .env.example — Copy to .env and review before running scripts.
# Phase 0 preflight will auto-populate this from your environment.

# --- GitHub (auto-populated from git remote) ---
GITHUB_OWNER=
GITHUB_REPO=
CONTAINER_IMAGE=ghcr.io/${GITHUB_OWNER}/${GITHUB_REPO}:latest

# --- Azure (auto-populated from az CLI) ---
AZURE_SUBSCRIPTION_NAME=
AZURE_SUBSCRIPTION_ID=
AZURE_LOCATION=northeurope

# --- Azure Resource Names ---
RESOURCE_GROUP=rg-connectivity-test
ENVIRONMENT=cae-connectivity-test
APP_NAME=connectivity-animation-test

# --- App ---
APP_PORT=3000
